#!/usr/bin/env bash
# tai - Tail an AI agent log and narrate what's happening using a fast model.
#
# Currently understands Claude Code stream-json logs (assistant text, tool_use,
# tool_result events). One short sentence per change is printed to stdout.
#
# Usage: tai <log-file>
# Env:
#   TAI_MODEL    model passed to `claude -p` (default: claude-haiku-4-5)
#   TAI_IDLE     seconds of idleness before flushing the buffer (default: 3)
#   TAI_MAX_BUF  max events buffered before forcing a flush (default: 40)
#   TAI_TAIL     raw lines of existing log to seed context on startup
#                (default: 200). These lines are NOT summarized on their own;
#                they only provide context when the next new line arrives.
#                Set to 0 to behave like `tail -n 0 -F`.
#   TAI_RING     max events kept in the rolling context window (default: 50).

set -uo pipefail

MODEL="${TAI_MODEL:-claude-haiku-4-5}"
IDLE_FLUSH="${TAI_IDLE:-3}"
MAX_BUF="${TAI_MAX_BUF:-40}"
TAIL_LINES="${TAI_TAIL:-200}"
RING_SIZE="${TAI_RING:-50}"

SYSTEM='You narrate what an AI coding agent is doing, in real time, for a human watching. You will receive a chunk of recent events: [say] = assistant text, [tool:Name] = tool call, [result] = tool result. Reply with ONE short sentence (max ~20 words) describing what is happening NOW. Be concrete: name the tool/file/command if relevant. No preamble, no quotes, no markdown.'

usage() {
  cat <<EOF
usage: tai <log-file>

Tails a Claude Code stream-json log and narrates the agent's activity
using a fast model (default: claude-haiku-4-5).

On startup, seeds a context buffer from the last TAI_TAIL raw lines but
does NOT summarize until at least one new line is appended. This way
tai is silent against stale logs and only invokes the model when there
is genuinely new activity to narrate.

Env vars: TAI_MODEL, TAI_IDLE, TAI_MAX_BUF, TAI_TAIL, TAI_RING
EOF
}

if [[ $# -lt 1 || "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage; exit 2
fi

LOG="$1"

for cmd in jq claude tail; do
  command -v "$cmd" >/dev/null 2>&1 || { echo "tai: requires '$cmd' on PATH" >&2; exit 1; }
done

while [[ ! -e "$LOG" ]]; do
  echo "tai: waiting for $LOG ..." >&2
  sleep 0.5
done

# jq filter: turn stream-json lines into one-line human-readable events.
# Uses -R to read raw lines and `fromjson?` to skip non-JSON header/blank lines.
JQ_FILTER='
def trunc: tostring | gsub("\n"; " ") | if length > 400 then .[0:400] + "…" else . end;
fromjson? // empty |
if .type == "assistant" then
  (.message.content // [])[]
  | if .type == "text" and ((.text // "") | length) > 0 then
      "[say] " + (.text | trunc)
    elif .type == "tool_use" then
      "[tool:" + (.name // "?") + "] " +
      ((.input.description // .input.command // .input.file_path // .input.pattern // (.input | tostring)) | trunc)
    else empty end
elif .type == "user" then
  (.message.content // [])[]
  | select(type == "object" and .type == "tool_result")
  | ((.content | if type == "array" then map(.text // "") | join(" ") else tostring end) | trunc) as $c
  | (if .is_error == true then "[result ERROR] " else "[result] " end) + $c
else empty end
'

echo "tai: watching $LOG  (model=$MODEL, idle=${IDLE_FLUSH}s, seed=${TAIL_LINES} lines)" >&2

LAST_SUMMARY=""

flush() {
  local payload="$1"
  [[ -z "$payload" ]] && return 0
  local out
  out=$(claude -p --model "$MODEL" --append-system-prompt "$SYSTEM" "$payload" 2>/dev/null) || return 0
  out="$(printf '%s' "$out" | tr -d '\r' | awk 'NF{print; exit}')"
  [[ -z "$out" ]] && return 0
  if [[ "$out" == "$LAST_SUMMARY" ]]; then return 0; fi
  LAST_SUMMARY="$out"
  printf '%s  %s\n' "$(date +%H:%M:%S)" "$out"
}

# Stream: tail -F | jq | read loop with idle timeout.
# Uses a coproc-style pipe via process substitution so `read -t` works.
{
  tail -n "$TAIL_LINES" -F "$LOG" 2>/dev/null \
    | jq -rcR --unbuffered "$JQ_FILTER" 2>/dev/null
} | {
  # macOS bash 3.2 returns 1 from `read -t` on BOTH timeout and EOF, so we
  # disambiguate by elapsed wall-clock: a near-instant return means the
  # upstream pipe closed (EOF); a near-IDLE_FLUSH return means timeout.
  #
  # We keep a rolling ring of the most recent events purely as context. The
  # model is only invoked when at least one NEW line has arrived since the
  # last flush — so a stale log produces zero agent calls.
  EVENTS=()
  NEW=0

  push_event() {
    EVENTS+=("$1")
    if (( ${#EVENTS[@]} > RING_SIZE )); then
      EVENTS=("${EVENTS[@]:1}")
    fi
  }

  flush_events() {
    local payload="" e
    for e in "${EVENTS[@]}"; do payload+="$e"$'\n'; done
    flush "$payload"
    NEW=0
  }

  # --- Seed phase: drain whatever the initial `tail -n N` emits, with no
  # agent calls. We treat a 1-second idle as "seed exhausted, now live".
  while IFS= read -r -t 1 line; do
    [[ -z "$line" ]] && continue
    push_event "$line"
  done

  # --- Live phase: only new lines (appended after we started watching)
  # contribute to NEW, and only NEW>0 triggers a flush.
  while :; do
    start=$(date +%s)
    if IFS= read -r -t "$IDLE_FLUSH" line; then
      [[ -z "$line" ]] && continue
      push_event "$line"
      NEW=$((NEW + 1))
      if (( NEW >= MAX_BUF )); then
        flush_events
      fi
    else
      elapsed=$(( $(date +%s) - start ))
      if (( NEW > 0 )); then
        flush_events
      fi
      if (( elapsed + 1 < IDLE_FLUSH )); then
        exit 0
      fi
    fi
  done
}
